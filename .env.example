# Copie ce fichier en .env et remplis avec tes vraies valeurs.
# Le fichier .env n'est jamais pousse sur GitHub (voir .gitignore).

# --- Base de donnees ---
# Par defaut on utilise SQLite (aucune install necessaire).
# Pour passer sur PostgreSQL plus tard, il suffit de changer cette URL.
DATABASE_URL=sqlite:///data/db/opportunity.db

# --- Scraping ---
# Delai (en secondes) entre deux requetes, pour rester poli avec les serveurs.
SCRAPING_DELAY=2.0
# User-Agent envoye dans les requetes HTTP.
USER_AGENT=OpportunitySN-Bot/1.0 (+https://github.com/pa-malick)

# --- Email (notifications) ---
# Exemple avec un compte Gmail + mot de passe d'application.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.email@gmail.com
SMTP_PASSWORD=ton_mot_de_passe_application
EMAIL_FROM=ton.email@gmail.com
EMAIL_TO=destinataire@gmail.com

# Mettre a true pour vraiment envoyer les emails, false pour juste simuler (mode dev).
EMAIL_ENABLED=false

# --- Analyse ---
# Seuil du Z-score au dela duquel on considere une valeur comme anormale.
ZSCORE_THRESHOLD=2.5

# --- Automatisation no-code (Make / Zapier) ---
# URL du webhook Make (ou Zapier) qui recevra les alertes au format JSON.
# Make se charge ensuite de router vers Slack, Google Sheets, WhatsApp, email.
# On cree ce webhook gratuitement dans Make : module "Webhooks > Custom webhook".
MAKE_WEBHOOK_URL=
# Mettre a true pour vraiment envoyer vers Make, false pour juste simuler.
WEBHOOK_ENABLED=false
