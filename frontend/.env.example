# Copie ce fichier en .env et remplis la valeur.
# Les variables VITE_* sont injectees dans le front au build.

# URL du webhook Make qui recoit les abonnements (email des utilisateurs).
# On cree un scenario Make : Webhook -> Google Sheets (ajoute une ligne) ou
# Webhook -> Email de confirmation. Puis on colle l'URL du webhook ici.
VITE_MAKE_SUBSCRIBE_URL=
